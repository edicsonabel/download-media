  RED=$'\e[0;31m';   BOLD=$'\e[1m';    DIM=$'\e[2m'; RESET=$'\e[0m'
else
  GREEN=""; CYAN=""; YELLOW=""; RED=""; BOLD=""; DIM=""; RESET=""
fi

