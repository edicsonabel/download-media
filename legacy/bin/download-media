#!/bin/bash
#
# download-media — interactive wrapper for yt-dlp
#
# Features:
#   - Wizard mode (step-by-step prompts)
#   - Direct CLI mode with flags
#   - Clipboard fallback (auto-detects URL in clipboard)
#   - Playlist auto-detection with interactive choice
#   - Preview + confirmation before downloading
#   - Subtitle download (--subs)
#   - Browser cookies (--cookies <browser>) for private/age-gated content
#   - Download history log
#
# License: MIT

set -euo pipefail

VERSION="0.0.1"

# ---------------------------------------------------------------------------
# Colors (disabled if stdout is not a TTY)
# ---------------------------------------------------------------------------
